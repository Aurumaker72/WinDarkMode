#include <windows.h>
#include <commctrl.h>
#include "resource.h"

IDR_MAIN_MENU MENU
BEGIN
    POPUP "&Window"
    BEGIN
        MENUITEM "&Close",              IDM_CLOSE
        MENUITEM "Toggle &Tool Window", IDM_TOGGLE_WINDOW
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&File Dialog",        IDM_FILE_DLG
        MENUITEM "Co&lor Dialog",       IDM_COLOR_DLG
    END
END

IDD_MAIN_DIALOG DIALOGEX 0, 0, 380, 278
STYLE DS_SETFONT | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX
MENU IDR_MAIN_MENU
CAPTION "WinDarkMode Demo"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    GROUPBOX        "Theme",                IDC_STATIC,         4,   4, 364,  24
    AUTORADIOBUTTON "Light",                IDC_THEME_LIGHT,   10,  14,  42,  10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "Dark",                 IDC_THEME_DARK,    58,  14,  42,  10
    AUTORADIOBUTTON "System (follow OS)",   IDC_THEME_SYSTEM, 106,  14,  92,  10

    LTEXT           "Pushbutton:",          IDC_STATIC,         4,  34,  54,   8
    PUSHBUTTON      "Standard",             IDC_BUTTON1,        4,  44,  50,  14
    PUSHBUTTON      "Disabled",             IDC_BTN_DISABLED,   4,  62,  50,  14, WS_DISABLED

    LTEXT           "Radiobutton:",         IDC_STATIC,        60,  34,  58,   8
    AUTORADIOBUTTON "Unset",                IDC_DEMO_RADIO1,   60,  44,  52,  10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "Unset Disabled",       IDC_DEMO_RADIO2,   60,  56,  76,  10, WS_DISABLED
    AUTORADIOBUTTON "Set",                  IDC_DEMO_RADIO3,   60,  68,  30,  10

    LTEXT           "Checkbox:",            IDC_STATIC,       138,  34,  48,   8
    AUTOCHECKBOX    "Unchecked",            IDC_CHK1,         138,  44,  64,  10
    AUTOCHECKBOX    "Unchecked Disabled",   IDC_CHK2,         138,  56,  94,  10, WS_DISABLED
    AUTOCHECKBOX    "Checked",              IDC_CHK3,         138,  68,  52,  10
    AUTOCHECKBOX    "Checked Disabled",     IDC_CHK4,         138,  80,  82,  10, WS_DISABLED
    CONTROL "Tri-state",                    IDC_CHK5, "Button", BS_AUTO3STATE | WS_TABSTOP | WS_CHILD | WS_VISIBLE,               138,  92,  48,  10
    CONTROL "Tri-state Disabled",           IDC_CHK6, "Button", BS_AUTO3STATE | WS_DISABLED | WS_TABSTOP | WS_CHILD | WS_VISIBLE, 138, 104,  76,  10

    LTEXT           "Edit:",                IDC_STATIC,       238,  34,  25,   8
    EDITTEXT                                IDC_EDIT_NORMAL,  238,  44,  72,  12
    EDITTEXT                                IDC_EDIT_DISABLED,238,  60,  72,  12, WS_DISABLED
    EDITTEXT                                IDC_EDIT_PASSWORD,238,  76,  72,  12, ES_PASSWORD
    EDITTEXT                                IDC_EDIT_READONLY,238,  92,  72,  12, ES_READONLY

    LTEXT           "Combobox:",            IDC_STATIC,       316,  34,  50,   8
    COMBOBOX                                IDC_COMBO1,       316,  44,  56,  64, CBS_DROPDOWN     | WS_VSCROLL | WS_TABSTOP
    COMBOBOX                                IDC_COMBO2,       316,  62,  56,  64, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    COMBOBOX                                IDC_COMBO3,       316,  80,  56,  64, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP | WS_DISABLED

    GROUPBOX        "Group Box",            IDC_STATIC,         4, 122, 116,  36
    LTEXT           "Spinner:",             IDC_STATIC,        10, 135,  35,   8
    EDITTEXT                                IDC_SPINNER_EDIT,  48, 133,  56,  12, ES_NUMBER | WS_TABSTOP

    LTEXT           "Link:",                IDC_STATIC,       130, 131,  25,   8
    CONTROL         "<a>example.com</a>",   IDC_LINK1, "SysLink", WS_TABSTOP | WS_CHILD | WS_VISIBLE, 130, 143, 82, 10

    CONTROL         "",                     IDC_TAB1, "SysTabControl32", WS_TABSTOP | WS_CHILD | WS_VISIBLE, 238, 122, 130, 48

    LTEXT           "Progressbar:",         IDC_STATIC,         4, 174,  58,   8
    CONTROL "",  IDC_PROG_NORMAL,  "msctls_progress32", WS_CHILD | WS_VISIBLE,                4, 184,  78,  12
    LTEXT           "Normal",               IDC_STATIC,        85, 187,  30,   8
    CONTROL "",  IDC_PROG_ERROR,   "msctls_progress32", WS_CHILD | WS_VISIBLE,                4, 198,  78,  12
    LTEXT           "Error",                IDC_STATIC,        85, 201,  25,   8
    CONTROL "",  IDC_PROG_PAUSED,  "msctls_progress32", WS_CHILD | WS_VISIBLE,                4, 212,  78,  12
    LTEXT           "Paused",               IDC_STATIC,        85, 215,  30,   8
    CONTROL "",  IDC_PROG_MARQUEE, "msctls_progress32", PBS_MARQUEE | WS_CHILD | WS_VISIBLE,  4, 226,  78,  12
    LTEXT           "Marquee",              IDC_STATIC,        85, 229,  36,   8

    LTEXT           "Listbox:",             IDC_STATIC,       122, 174,  38,   8
    LISTBOX                                 IDC_LISTBOX,      122, 184,  64,  56, LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Listview:",            IDC_STATIC,       190, 174,  40,   8
    CONTROL "",                             IDC_LISTVIEW, "SysListView32", LVS_REPORT | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP | WS_CHILD | WS_VISIBLE, 190, 184, 78, 56

    LTEXT           "Treeview:",            IDC_STATIC,       272, 174,  40,   8
    CONTROL "",                             IDC_TREEVIEW, "SysTreeView32", TVS_HASLINES | TVS_LINESATROOT | TVS_HASBUTTONS | WS_BORDER | WS_TABSTOP | WS_CHILD | WS_VISIBLE, 272, 184, 96, 56

    LTEXT           "Trackbar:",            IDC_STATIC,         4, 250,  40,   8
    CONTROL "",                             IDC_TRACKBAR, "msctls_trackbar32", TBS_AUTOTICKS | WS_TABSTOP | WS_CHILD | WS_VISIBLE, 46, 246, 72, 22

    CONTROL "", IDC_HSCROLL, "ScrollBar", SBS_HORZ | WS_CHILD | WS_VISIBLE,   0, 270, 370,   8
    CONTROL "", IDC_VSCROLL, "ScrollBar", SBS_VERT | WS_CHILD | WS_VISIBLE, 370,   0,  10, 270
END

1 RT_MANIFEST "app.manifest"

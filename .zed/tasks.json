[
  {
    "label": "cmake: configure",
    "command": "cmake",
    "args": [
      "--preset",
      "debug"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "save": "none",
    "reveal": "always"
  },
  {
    "label": "cmake: build",
    "command": "cmake",
    "args": [
      "--build",
      "--preset",
      "debug"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "save": "all",
    "reveal": "always"
  },
  {
    "label": "cmake: clean",
    "command": "cmake",
    "args": [
      "--build",
      "--preset",
      "debug",
      "--target",
      "clean"
    ],
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "save": "none",
    "reveal": "always"
  },
  {
    "label": "cmake: rebuild",
    "command": "cmake -E rm -rf build && cmake --preset debug && cmake --build --preset debug",
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "save": "all",
    "reveal": "always",
    "allow_concurrent_runs": false
  },
  {
    "label": "demo: run",
    "command": "build/debug/Debug/WinDarkModeDemo.exe",
    "cwd": "$ZED_WORKTREE_ROOT/demo",
    "save": "none",
    "reveal": "always",
    "use_new_terminal": true,
    "allow_concurrent_runs": true
  }
]
